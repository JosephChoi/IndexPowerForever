{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(del *)",
      "Bash(rmdir *)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git clean*)",
      "Bash(curl*)",
      "Bash(wget*)",
      "Bash(sudo*)",
      "Bash(eval*)",
      "Bash(exec*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/validate-viewlogic.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/validate-backend.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/validate-structure.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
